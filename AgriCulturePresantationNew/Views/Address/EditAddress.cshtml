@model EntityLayer.Concrete.Address
@{
	ViewData["Title"] = "EditAddress";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title"> Adres Bilgisi Düzenleme Sayfası</h4>

            <form class="forms-sample" method="post">
                <input type="hidden" asp-for="AddressID" />
                <div class="form-group">
                    <label for="exampleInputName1">Açıklama 1</label>
                    <span asp-validation-for="Description1"class="text-danger"></span>
                    <input type="text" class="form-control"id="exampleInputName1" placeholder="Açıklama 1 " asp-for="Description1">
                </div>
                <br />

                <div class="form-group">
                    <label for="exampleInputName1">Açıklama 2</label>
                    <span asp-validation-for="Description2"class="text-danger"></span>
                    <input type="text" class="form-control"id="exampleInputName1" placeholder="Açıklama 2" asp-for="Description2">
                </div>
                <br />

                <div class="form-group">
                    <label for="exampleInputName1">Açıklama 3</label>
                    <span asp-validation-for="Description3"class="text-danger"></span>
                    <input type="text" class="form-control"id="exampleInputName1" placeholder="Açıklama 3" asp-for="Description3">
                </div>
                <br />

                <div class="form-group">
                    <label for="exampleInputName1">Açıklama 4</label>
                    <span asp-validation-for="Description4"class="text-danger"></span>
                    <input type="text" class="form-control"id="exampleInputName1" placeholder="Açıklama 4" asp-for="Description4">
                </div>
                <br />
                <div class="form-group">
                    <label for="exampleInputName1">Harita</label>
                    <span asp-validation-for="MapInfo" class="text-danger"></span>
                    <input type="text" class="form-control" id="exampleInputName1" placeholder="Harita Bilgisi" asp-for="MapInfo">
                </div>
                <br />

                    <button type="submit" class="btn btn-outline-info">Kaydet</button>
                    <button type="reset" class="btn btn-outline-dark">İptal</button>
            </form>
        </div>
    </div>
</div>