@using EntityLayer.Concrete
@model List<Image>
@{

	ViewData["Title"] = "Index";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
			<h4 class="card-title">Görsel Listesi</h4>
            
            <div class="table-responsive">
                @if (Model == null || !Model.Any())
                {
                    @* Personel yoksa burası çalışır *@
                    <div class="alert alert-info text-center">
                        <p style="font-size:1.2rem; margin-bottom:15px;">Sistemde henüz kayıtlı bir görsel bulunamadı.</p>
                        <a href="/Image/AddImage" class="btn btn-primary">İlk görseli Sen Ekle</a>
                    </div>
                }
                else{
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                           <th>Başlık</th>
                           <th>Sil</th>
                           <th>Düzenle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model)
                        {
                        <tr>
                            <td class="py-1"><img src="@item.ImageUrl" alt="image" /></td>
                            <td>@item.Title</td>
                                <td><a href="/Image/DeleteImage/@item.ImageID" class="btn btn-outline-danger">Sil</a></td>
                                <td><a href="/Image/EditImage/@item.ImageID" class="btn btn-outline-success">Güncelle</a></td>
                       
                        </tr>
                      }
                    </tbody>
                </table>
                <br />
                <a href="/Image/AddImage" class="btn btn-outline-info">Yeni Görsel Girişi</a>
                }
            </div>
        </div>
    </div>
</div>